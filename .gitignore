# Build outputs
/build
/out
/.vs

# Native build directories
/native/build
/native/build-android*
/native/target

# Rust build logs
native/check.log

# .NET build artifacts (all platforms)

# Distribution / publish outputs
/dist

# Temporary build artifacts that should never be in the repo root
/*.exe
/*.o
/*.obj
/*.wasm
/*.wat
/*.ilk
/*.pdb
/*.lib
/*.dll
*.so
/*.tmp
*.log


# IDE / editor
*.user
*.suo
**/.vs/
.vscode/settings.json
.idea/
**/Properties/launchSettings.json

# OS
.DS_Store
Thumbs.db

# Test & coverage
TestResults/
coverage/
*.coverage
*.coveragexml

# Shadow verification framework (auto-generated reports)
native/tests/shadow_verification/reports/
!native/tests/shadow_verification/reports/SHADOW_VERIFICATION_REPORT_*.md
!native/tests/shadow_verification/reports/.gitkeep

# Three tier test reports (auto-generated by CI)
reports/
!reports/.gitkeep

# Template sync & e2e auto-generated artifacts
native/tests/cases_golden/golden_failures.log
native/tests/TEST_REPORT.md

# Build logs & artifacts
*.binlog
artifacts/

# Package manager
*.nupkg
packages/
.tmp-monaco/
node_modules/

# Blazor / static web assets generated from NuGet packages
**/wwwroot/_content/

# ==========================================
# Flutter frontend (CideFlutter/)
# ==========================================
# Build outputs
/CideFlutter/build/
/CideFlutter/.dart_tool/
/CideFlutter/.flutter-plugins
/CideFlutter/.flutter-plugins-dependencies
/CideFlutter/*.iml
/CideFlutter/.idea/
/CideFlutter/.metadata
/CideFlutter/pubspec.lock

# Flutter generated files
/CideFlutter/lib/src/rust/frb_generated*.dart
/CideFlutter/lib/src/rust/api/*.dart
!/CideFlutter/lib/src/rust/api/.gitkeep
!/CideFlutter/lib/src/rust/api/types.dart

# iOS / macOS / Linux / Windows build artifacts
/CideFlutter/ios/Flutter/Generated.xcconfig
/CideFlutter/ios/Runner/GeneratedPluginRegistrant.*
/CideFlutter/macos/Flutter/GeneratedPluginRegistrant.*
/CideFlutter/macos/Flutter/ephemeral/
/CideFlutter/linux/flutter/generated_plugin_registrant.*
/CideFlutter/linux/flutter/generated_plugins.cmake
/CideFlutter/windows/flutter/generated_plugin_registrant.cc
/CideFlutter/windows/flutter/generated_plugin_registrant.h
/CideFlutter/windows/flutter/generated_plugins.cmake

# Android build artifacts (kept: build.gradle, settings.gradle, etc.)
/CideFlutter/android/.gradle/
/CideFlutter/android/app/debug/
/CideFlutter/android/app/profile/
/CideFlutter/android/app/release/
/CideFlutter/android/build/
/CideFlutter/android/gradle/gradle-8.13-bin.zip

# Rust builder plugin (auto-generated by FRB integrate)
# cargokit/ 包含 CMake 构建脚本，CI 需要，不能忽略
# /CideFlutter/rust_builder/cargokit/
/CideFlutter/rust_builder/android/.gradle/
/CideFlutter/rust_builder/android/src/main/jniLibs/

# Offline local packages (kept: packages/ folder itself, but not build artifacts)
/CideFlutter/packages/**/example/
/CideFlutter/packages/**/.dart_tool/
/CideFlutter/packages/**/build/
/CideFlutter/packages/**/pubspec.lock

# Python
*.pyc
**/__pycache__/
scripts/__pycache__/
native/tests/test_detect.*
native/test_*_c_clang.exe
native/tests/bytecode_libc_consistency/*.exe
native/examples/repro*.rs

# ==========================================
# 补充：防止构建产物再次进入历史
# ==========================================
# Android CMake 生成的编译器检测文件
**/CMakeFiles/**/CMakeCXXCompilerId.cpp
**/CMakeFiles/**/CMakeCCompilerId.c

# Flutter Android .cxx 目录（NDK 构建缓存）
CideFlutter/android/app/.cxx/

# Windows 桌面构建产物
CideFlutter/build/windows/
CideFlutter/build/web/

# iOS/macOS 构建产物
CideFlutter/build/ios/
CideFlutter/build/macos/

# 第三方库 map 文件（体积大且非必须）
**/*.css.map
**/*.js.map

# 字体文件（如果很大且可外部获取）
# 注意：保留 .ttf 跟踪，因为可能是自定义字体
# 如果是标准开源字体（如 OpenSans），建议改为 CDN 引用

# Rust 增量编译产物（保险起见）
native/target/
**/*.rmeta
**/*.timestamp
