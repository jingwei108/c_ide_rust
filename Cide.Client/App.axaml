<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Cide.Client"
             x:Class="Cide.Client.App">
    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <!-- ========== 深色主题 ========== -->
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AppBackgroundBrush">#1E1E1E</SolidColorBrush>
                    <SolidColorBrush x:Key="AppPanelBrush">#252526</SolidColorBrush>
                    <SolidColorBrush x:Key="AppCardBrush">#2D2D30</SolidColorBrush>
                    <SolidColorBrush x:Key="AppPopupBrush">#2D2D30</SolidColorBrush>
                    <SolidColorBrush x:Key="AppBorderBrush">#3E3E3E</SolidColorBrush>
                    <SolidColorBrush x:Key="AppTextBrush">#D4D4D4</SolidColorBrush>
                    <SolidColorBrush x:Key="AppTextSecondaryBrush">#CCCCCC</SolidColorBrush>
                    <SolidColorBrush x:Key="AppTextMutedBrush">#808080</SolidColorBrush>
                    <SolidColorBrush x:Key="AppButtonBrush">#2D2D30</SolidColorBrush>
                    <SolidColorBrush x:Key="AppButtonHoverBrush">#3E3E42</SolidColorBrush>
                    <SolidColorBrush x:Key="AppButtonSecondaryBrush">#3A3A3C</SolidColorBrush>
                    <SolidColorBrush x:Key="AppButtonSecondaryHoverBrush">#4A4A4C</SolidColorBrush>
                    <SolidColorBrush x:Key="AppFanBrush">#CC2D2D30</SolidColorBrush>
                    <SolidColorBrush x:Key="AppFanTextBrush">#FFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="AppFanBorderBrush">#55FFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="AppSyntaxKeywordBrush">#9CDCFE</SolidColorBrush>
                    <SolidColorBrush x:Key="AppSyntaxValueBrush">#B5CEA8</SolidColorBrush>
                    <SolidColorBrush x:Key="AppSyntaxFunctionBrush">#CE9178</SolidColorBrush>
                    <SolidColorBrush x:Key="AppSyntaxErrorBrush">#F48771</SolidColorBrush>
                    <SolidColorBrush x:Key="AppSyntaxWarningBrush">#CCA700</SolidColorBrush>
                    <SolidColorBrush x:Key="AppSyntaxSeverityBrush">#C586C0</SolidColorBrush>
                    <Color x:Key="AppErrorBgColor">#3C1E1E</Color>
                    <Color x:Key="AppWarningBgColor">#3A3A1E</Color>
                    <Color x:Key="AppHintBgColor">#1E3A3A</Color>
                    <SolidColorBrush x:Key="AppAlgorithmBgBrush">#1E3A1E</SolidColorBrush>
                    <SolidColorBrush x:Key="AppWrongCodeBgBrush">#3C1E1E</SolidColorBrush>
                    <SolidColorBrush x:Key="AppCorrectCodeBgBrush">#1E3A1E</SolidColorBrush>
                </ResourceDictionary>

                <!-- ========== 白天主题 ========== -->
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AppBackgroundBrush">#FFFFFF</SolidColorBrush>
                    <SolidColorBrush x:Key="AppPanelBrush">#F5F5F5</SolidColorBrush>
                    <SolidColorBrush x:Key="AppCardBrush">#EFEFEF</SolidColorBrush>
                    <SolidColorBrush x:Key="AppPopupBrush">#F5F5F5</SolidColorBrush>
                    <SolidColorBrush x:Key="AppBorderBrush">#D0D0D0</SolidColorBrush>
                    <SolidColorBrush x:Key="AppTextBrush">#1E1E1E</SolidColorBrush>
                    <SolidColorBrush x:Key="AppTextSecondaryBrush">#333333</SolidColorBrush>
                    <SolidColorBrush x:Key="AppTextMutedBrush">#666666</SolidColorBrush>
                    <SolidColorBrush x:Key="AppButtonBrush">#E8E8E8</SolidColorBrush>
                    <SolidColorBrush x:Key="AppButtonHoverBrush">#D0D0D0</SolidColorBrush>
                    <SolidColorBrush x:Key="AppButtonSecondaryBrush">#E0E0E0</SolidColorBrush>
                    <SolidColorBrush x:Key="AppButtonSecondaryHoverBrush">#D0D0D0</SolidColorBrush>
                    <SolidColorBrush x:Key="AppFanBrush">#D9F5F5F5</SolidColorBrush>
                    <SolidColorBrush x:Key="AppFanTextBrush">#1E1E1E</SolidColorBrush>
                    <SolidColorBrush x:Key="AppFanBorderBrush">#55AAAAAA</SolidColorBrush>
                    <SolidColorBrush x:Key="AppSyntaxKeywordBrush">#007ACC</SolidColorBrush>
                    <SolidColorBrush x:Key="AppSyntaxValueBrush">#388E3C</SolidColorBrush>
                    <SolidColorBrush x:Key="AppSyntaxFunctionBrush">#D84315</SolidColorBrush>
                    <SolidColorBrush x:Key="AppSyntaxErrorBrush">#D32F2F</SolidColorBrush>
                    <SolidColorBrush x:Key="AppSyntaxWarningBrush">#F57F17</SolidColorBrush>
                    <SolidColorBrush x:Key="AppSyntaxSeverityBrush">#7B1FA2</SolidColorBrush>
                    <Color x:Key="AppErrorBgColor">#FFE5E5</Color>
                    <Color x:Key="AppWarningBgColor">#FFF8E1</Color>
                    <Color x:Key="AppHintBgColor">#E3F2FD</Color>
                    <SolidColorBrush x:Key="AppAlgorithmBgBrush">#E8F5E9</SolidColorBrush>
                    <SolidColorBrush x:Key="AppWrongCodeBgBrush">#FFEBEE</SolidColorBrush>
                    <SolidColorBrush x:Key="AppCorrectCodeBgBrush">#E8F5E9</SolidColorBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml" />
    </Application.Styles>
</Application>
