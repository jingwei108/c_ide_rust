<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Cide.Client.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:system="clr-namespace:System;assembly=System.Runtime"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
             x:Class="Cide.Client.Views.MainView"
             x:DataType="vm:MainViewModel"
             xmlns:core="using:Cide.Client.Core"
             xmlns:views="using:Cide.Client.Views">
  <UserControl.Resources>
    <!-- ==================== 响应式设计令牌 ==================== -->
    <!-- 以 400px 逻辑宽度为基准，由 MainView.axaml.cs 动态覆写 -->

    <!-- 工具栏 -->
    <Thickness x:Key="MobileToolbarPadding">8,28,8,6</Thickness>
    <Thickness x:Key="MobileBtnPadding">14,6</Thickness>
    <system:Double x:Key="MobileBtnFontSize">14</system:Double>
    <system:Double x:Key="MobileStepBtnFontSize">13</system:Double>
    <system:Double x:Key="MobileSliderWidth">80</system:Double>
    <Thickness x:Key="MobileStatusPadding">8,4</Thickness>
    <system:Double x:Key="MobileStatusFontSize">11</system:Double>

    <!-- 编辑器区域 -->
    <Thickness x:Key="EditorMargin">4</Thickness>
    <system:Double x:Key="EditorFontSize">14</system:Double>
    <Thickness x:Key="EditorPadding">8,4,8,4</Thickness>
    <system:Double x:Key="LineNumberWidth">48</system:Double>
    <Thickness x:Key="LineNumberMargin">0,4,0,0</Thickness>
    <Thickness x:Key="LineNumberItemMargin">2,0,2,0</Thickness>
    <Thickness x:Key="LineNumberEllipseMargin">4,0,0,0</Thickness>
    <Thickness x:Key="LineNumberTextPadding">0,2,8,2</Thickness>
    <system:Double x:Key="LineNumberFontSize">13</system:Double>

    <!-- 底部面板 -->
    <system:Double x:Key="BottomPanelHeight">140</system:Double>
    <Thickness x:Key="BottomPanelMargin">4</Thickness>
    <Thickness x:Key="ConsoleOutputMargin">8</Thickness>
    <system:Double x:Key="ConsoleOutputFontSize">14</system:Double>

    <!-- 模板栏 -->
    <Thickness x:Key="TemplateBarMargin">4</Thickness>
    <Thickness x:Key="TemplateBarItemMargin">4,0</Thickness>
    <Thickness x:Key="TemplateBtnPadding">8,4</Thickness>
    <system:Double x:Key="TemplateBtnFontSize">12</system:Double>
    <CornerRadius x:Key="TemplateBtnCornerRadius">12</CornerRadius>

    <!-- 底部标签栏 -->
    <system:Double x:Key="TabHeaderFontSize">12</system:Double>
    <Thickness x:Key="TabHeaderPadding">8,4</Thickness>
    <system:Double x:Key="TabItemWidth">120</system:Double>

    <!-- 诊断/算法卡片 -->
    <Thickness x:Key="CardPadding">8</Thickness>
    <Thickness x:Key="CardMargin">0,4</Thickness>
    <CornerRadius x:Key="CardCornerRadius">4</CornerRadius>
    <Thickness x:Key="CardInnerPadding">6</Thickness>
    <CornerRadius x:Key="CardInnerCornerRadius">2</CornerRadius>
    <system:Double x:Key="CardFontSize">11</system:Double>
    <system:Double x:Key="CardTitleFontSize">12</system:Double>

    <!-- 桌面调试面板 -->
    <system:Double x:Key="DebugPanelWidth">300</system:Double>
    <Thickness x:Key="DebugPanelMargin">4,0,0,0</Thickness>
    <Thickness x:Key="DebugPanelHeaderMargin">8,8,8,4</Thickness>
    <system:Double x:Key="DebugPanelHeaderFontSize">14</system:Double>
    <system:Double x:Key="DebugItemFontSize">12</system:Double>
    <Thickness x:Key="DebugItemPadding">6</Thickness>
    <Thickness x:Key="DebugItemMargin">0,2</Thickness>
    <CornerRadius x:Key="DebugItemCornerRadius">3</CornerRadius>
    <system:Double x:Key="DebugItemDetailFontSize">11</system:Double>

    <!-- 移动端模态面板 -->
    <system:Double x:Key="ModalWidth">360</system:Double>
    <system:Double x:Key="ModalHeight">520</system:Double>
    <CornerRadius x:Key="ModalCornerRadius">16</CornerRadius>
    <Thickness x:Key="ModalCloseBtnMargin">8</Thickness>
    <system:Double x:Key="ModalCloseBtnFontSize">16</system:Double>

    <!-- 悬浮球 -->
    <system:Double x:Key="FabAreaWidth">64</system:Double>
    <system:Double x:Key="FabAreaHeight">64</system:Double>
    <Thickness x:Key="FabAreaMargin">0</Thickness>
    <system:Double x:Key="FabSize">56</system:Double>
    <CornerRadius x:Key="FabCornerRadius">28</CornerRadius>
    <system:Double x:Key="FabFontSize">22</system:Double>
    <system:Double x:Key="FanBtnSize">44</system:Double>
    <CornerRadius x:Key="FanBtnCornerRadius">22</CornerRadius>
    <system:Double x:Key="FanBtnFontSize">16</system:Double>
    <system:Double x:Key="FabRadius">90</system:Double>
  </UserControl.Resources>

  <Grid x:Name="RootGrid" ColumnDefinitions="*, Auto">
    <!-- 左侧主区域 -->
    <Grid Grid.Column="0" RowDefinitions="Auto, *, Auto">
      <!-- 桌面端工具栏 -->
      <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="8"
                  IsVisible="{Binding Responsive.IsDesktop}">
        <Button Content="▶ 运行" Command="{Binding RunCodeCommand}" />
        <Button Content="⏭ 下一步" Command="{Binding StepNextCommand}" />
        <Button Content="⏹ 停止" Command="{Binding StopExecutionCommand}" />
        <ComboBox x:Name="TemplatePicker" Width="140" PlaceholderText="📋 模板"
                  ItemsSource="{Binding Templates}" VerticalAlignment="Center">
          <ComboBox.ItemTemplate>
            <DataTemplate x:DataType="vm:CodeTemplate">
              <TextBlock Text="{Binding DisplayName}" />
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
          <TextBlock Text="🐢" VerticalAlignment="Center" Foreground="{DynamicResource AppTextMutedBrush}" />
          <Slider Width="100" Minimum="0" Maximum="500" Value="{Binding ExecutionSpeed}" 
                  TickFrequency="50" TickPlacement="None" VerticalAlignment="Center" />
          <TextBlock Text="🐇" VerticalAlignment="Center" Foreground="{DynamicResource AppTextMutedBrush}" />
          <TextBlock Text="{Binding ExecutionSpeed, StringFormat='{}{0}ms'}" 
                     VerticalAlignment="Center" Foreground="{DynamicResource AppTextMutedBrush}" FontSize="11" Width="40" />
        </StackPanel>
        <TextBlock Text="{Binding StepStatusText}" 
                   VerticalAlignment="Center" Foreground="{DynamicResource AppTextMutedBrush}" Margin="16,0,0,0" />
      </StackPanel>

      <!-- 移动端工具栏：精简为一行，运行/停止合一，全部尺寸绑定 DynamicResource -->
      <Border Grid.Row="0"
              IsVisible="{Binding Responsive.IsDesktop, Converter={x:Static BoolConverters.Not}}"
              Background="{DynamicResource AppPanelBrush}"
              Padding="{DynamicResource MobileToolbarPadding}">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <!-- 运行 / 停止 合一：根据 IsRunning 自动切换 -->
          <Button Content="▶" Command="{Binding RunCodeCommand}"
                  IsVisible="{Binding IsRunning, Converter={x:Static BoolConverters.Not}}"
                  Background="#0A84FF" Foreground="White"
                  FontSize="{DynamicResource MobileBtnFontSize}"
                  Padding="{DynamicResource MobileBtnPadding}" CornerRadius="8" />
          <Button Content="■" Command="{Binding StopExecutionCommand}"
                  IsVisible="{Binding IsRunning}"
                  Background="#FF453A" Foreground="White"
                  FontSize="{DynamicResource MobileBtnFontSize}"
                  Padding="{DynamicResource MobileBtnPadding}" CornerRadius="8" />

          <Button Content="⏭ 下一步" Command="{Binding StepNextCommand}"
                  Background="{DynamicResource AppButtonSecondaryBrush}" Foreground="{DynamicResource AppTextSecondaryBrush}"
                  FontSize="{DynamicResource MobileStepBtnFontSize}"
                  Padding="{DynamicResource MobileBtnPadding}" CornerRadius="8" />

          <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
            <TextBlock Text="🐢" VerticalAlignment="Center" Foreground="{DynamicResource AppTextMutedBrush}"
                       FontSize="{DynamicResource MobileStatusFontSize}" />
            <Slider Width="{DynamicResource MobileSliderWidth}" Minimum="0" Maximum="500"
                    Value="{Binding ExecutionSpeed}" 
                    TickFrequency="50" TickPlacement="None" VerticalAlignment="Center" />
            <TextBlock Text="🐇" VerticalAlignment="Center" Foreground="{DynamicResource AppTextMutedBrush}"
                       FontSize="{DynamicResource MobileStatusFontSize}" />
          </StackPanel>

          <Border Background="{DynamicResource AppBackgroundBrush}" CornerRadius="6"
                  Padding="{DynamicResource MobileStatusPadding}" VerticalAlignment="Center">
            <TextBlock Text="{Binding StepStatusText}" 
                       VerticalAlignment="Center" Foreground="{DynamicResource AppSyntaxKeywordBrush}"
                       FontSize="{DynamicResource MobileStatusFontSize}" />
          </Border>

          <!-- 主题切换 -->
          <Button Content="亮" Command="{Binding ToggleThemeCommand}"
                  IsVisible="{Binding IsDarkMode}"
                  Background="Transparent" Foreground="{DynamicResource AppTextBrush}"
                  FontSize="{DynamicResource MobileBtnFontSize}"
                  Padding="8,4" CornerRadius="8"
                  BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" />
          <Button Content="暗" Command="{Binding ToggleThemeCommand}"
                  IsVisible="{Binding IsDarkMode, Converter={x:Static BoolConverters.Not}}"
                  Background="Transparent" Foreground="{DynamicResource AppTextBrush}"
                  FontSize="{DynamicResource MobileBtnFontSize}"
                  Padding="8,4" CornerRadius="8"
                  BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" />
        </StackPanel>
      </Border>

      <!-- 代码编辑器 -->
      <Grid Grid.Row="1" Margin="{DynamicResource EditorMargin}" ColumnDefinitions="*, Auto">
        <Grid Grid.Column="0" RowDefinitions="*, Auto">
          <Border Grid.Row="0" Background="{DynamicResource AppBackgroundBrush}">
            <views:CodeEditor x:Name="CodeEditor"
                              CodeText="{Binding SourceCode, Mode=TwoWay}"
                              ErrorLines="{Binding ErrorLines}"
                              WarningLines="{Binding WarningLines}"
                              BreakpointLines="{Binding BreakpointLines}"
                              Templates="{Binding Templates}" />
          </Border>
          <!-- 移动端模板快捷栏：非桌面时显示 -->
          <Border Grid.Row="1" Background="{DynamicResource AppPanelBrush}" 
                  IsVisible="{Binding Responsive.IsDesktop, Converter={x:Static BoolConverters.Not}}" 
                  BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,1,0,0">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Hidden">
              <StackPanel Orientation="Horizontal" Spacing="4" Margin="{DynamicResource TemplateBarMargin}">
                <TextBlock Text="📋" VerticalAlignment="Center" Margin="{DynamicResource TemplateBarItemMargin}" Foreground="{DynamicResource AppTextMutedBrush}" />
                <ItemsControl ItemsSource="{Binding Templates}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Horizontal" Spacing="4" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:CodeTemplate">
                      <Button Content="{Binding DisplayName}" 
                              Tag="{Binding Key}"
                              Click="OnTemplateButtonClick"
                              PointerPressed="OnTemplateButtonPressed"
                              Padding="{DynamicResource TemplateBtnPadding}"
                              FontSize="{DynamicResource TemplateBtnFontSize}"
                              Background="{DynamicResource AppButtonBrush}" Foreground="{DynamicResource AppTextSecondaryBrush}"
                              CornerRadius="{DynamicResource TemplateBtnCornerRadius}">
                        <Button.Styles>
                          <Style Selector="Button:pointerover /template/ ContentPresenter">
                            <Setter Property="Background" Value="{DynamicResource AppButtonHoverBrush}" />
                          </Style>
                          <Style Selector="Button:pressed /template/ ContentPresenter">
                            <Setter Property="Background" Value="#0A84FF" />
                            <Setter Property="Foreground" Value="#FFFFFF" />
                          </Style>
                        </Button.Styles>
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </ScrollViewer>
          </Border>
        </Grid>

        <!-- 平板横屏侧栏：输出/诊断/算法 -->
        <TabControl Grid.Column="1"
                    IsVisible="{Binding Responsive.IsLandscapeTablet}"
                    Width="280"
                    Background="{DynamicResource AppPanelBrush}"
                    SelectedIndex="{Binding SelectedTabIndex}">
          <TabControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </TabControl.ItemsPanel>
          <TabControl.Styles>
            <Style Selector="TabItem">
              <Setter Property="FontSize" Value="{DynamicResource TabHeaderFontSize}" />
              <Setter Property="Padding" Value="{DynamicResource TabHeaderPadding}" />
              <Setter Property="Width" Value="93" />
              <Setter Property="HorizontalContentAlignment" Value="Center" />
              <Setter Property="Background" Value="{DynamicResource AppPanelBrush}" />
              <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}" />
            </Style>
          </TabControl.Styles>
          <TabItem Header="输出">
            <Border Background="{DynamicResource AppPanelBrush}">
              <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding ConsoleOutput}" Foreground="{DynamicResource AppTextSecondaryBrush}"
                           FontFamily="Consolas, Courier New, monospace"
                           FontSize="{DynamicResource ConsoleOutputFontSize}"
                           Margin="{DynamicResource ConsoleOutputMargin}" TextWrapping="Wrap" />
              </ScrollViewer>
            </Border>
          </TabItem>
          <TabItem Header="诊断">
            <Border Background="{DynamicResource AppPanelBrush}">
              <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Diagnostics}" Margin="{DynamicResource CardPadding}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="core:Diagnostic">
                      <Border Background="{Binding Severity, Converter={x:Static vm:SeverityToBrushConverter.Instance}}"
                              CornerRadius="{DynamicResource CardCornerRadius}"
                              Padding="{DynamicResource CardPadding}"
                              Margin="{DynamicResource CardMargin}"
                              BoxShadow="0 1 4 0 #20000000"
                              BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1">
                        <StackPanel Spacing="4">
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding ErrorCode, StringFormat='[{0}]'}" Foreground="{DynamicResource AppSyntaxErrorBrush}" FontWeight="Bold" IsVisible="{Binding ErrorCode, Converter={x:Static vm:IntToBoolConverter.Instance}}" />
                            <TextBlock Text="{Binding Line, StringFormat='第{0}行'}" Foreground="{DynamicResource AppSyntaxKeywordBrush}" />
                            <TextBlock Text="{Binding Severity, StringFormat='严重度:{0}'}" Foreground="{DynamicResource AppSyntaxSeverityBrush}" />
                          </StackPanel>
                          <Border Background="{DynamicResource AppBackgroundBrush}" CornerRadius="{DynamicResource CardInnerCornerRadius}" Padding="{DynamicResource CardInnerPadding}" IsVisible="{Binding CodeSnippet, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                            <TextBlock Text="{Binding CodeSnippet}" Foreground="{DynamicResource AppTextBrush}" FontFamily="Consolas, Courier New, monospace" TextWrapping="NoWrap" />
                          </Border>
                          <TextBlock Text="{Binding Message}" Foreground="{DynamicResource AppTextBrush}" TextWrapping="Wrap" />
                          <TextBlock Text="{Binding FixSuggestion, StringFormat='💡 {0}'}" Foreground="{DynamicResource AppSyntaxValueBrush}"
                                     TextWrapping="Wrap" IsVisible="{Binding FixSuggestion, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                          <Button Content="应用修复"
                                  IsVisible="{Binding FixSuggestion, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                  Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).ApplyFixCommand}"
                                  CommandParameter="{Binding}"
                                  Background="#0A84FF" Foreground="#FFFFFF"
                                  Padding="8,4" CornerRadius="6"
                                  FontSize="12">
                            <Button.Styles>
                              <Style Selector="Button:pointerover /template/ ContentPresenter">
                                <Setter Property="Background" Value="#1E90FF" />
                              </Style>
                              <Style Selector="Button:pressed /template/ ContentPresenter">
                                <Setter Property="Background" Value="#005BB5" />
                              </Style>
                            </Button.Styles>
                          </Button>
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Border>
          </TabItem>
          <TabItem Header="算法">
            <Border Background="{DynamicResource AppPanelBrush}">
              <ScrollViewer>
                <ItemsControl ItemsSource="{Binding AlgorithmMatches}" Margin="{DynamicResource CardPadding}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="core:AlgorithmMatch">
                      <Border Background="{DynamicResource AppAlgorithmBgBrush}" CornerRadius="{DynamicResource CardCornerRadius}" Padding="{DynamicResource CardPadding}" Margin="{DynamicResource CardMargin}">
                        <StackPanel Spacing="4">
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource AppSyntaxValueBrush}" FontWeight="Bold" />
                            <TextBlock Text="{Binding Confidence, StringFormat='置信度:{0}%'}" Foreground="{DynamicResource AppTextMutedBrush}" />
                          </StackPanel>
                          <TextBlock Text="{Binding Suggestion}" Foreground="{DynamicResource AppTextBrush}" TextWrapping="Wrap" />
                          <Button Content="🔍 验证算法"
                                  Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).ValidateAlgorithmCommand}"
                                  CommandParameter="{Binding}"
                                  Background="#28a745" Foreground="#FFFFFF"
                                  Padding="8,4" CornerRadius="6"
                                  FontSize="12" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Border>
          </TabItem>
        </TabControl>
      </Grid>

      <!-- 底部面板：输出 + 诊断 + 算法，三键均分宽度（平板横屏时隐藏，由右侧侧栏替代） -->
      <TabControl Grid.Row="2" Height="{DynamicResource BottomPanelHeight}" Margin="{DynamicResource BottomPanelMargin}" Background="{DynamicResource AppPanelBrush}"
                  IsVisible="{Binding Responsive.IsLandscapeTablet, Converter={x:Static BoolConverters.Not}}">
        <TabControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Orientation="Horizontal" />
          </ItemsPanelTemplate>
        </TabControl.ItemsPanel>
        <TabControl.Styles>
          <Style Selector="TabItem">
            <Setter Property="FontSize" Value="{DynamicResource TabHeaderFontSize}" />
            <Setter Property="Padding" Value="{DynamicResource TabHeaderPadding}" />
            <Setter Property="Width" Value="{DynamicResource TabItemWidth}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource AppPanelBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextSecondaryBrush}" />
          </Style>
        </TabControl.Styles>
        <TabItem Header="输出">
          <Border Background="{DynamicResource AppPanelBrush}">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
              <TextBlock Text="{Binding ConsoleOutput}" Foreground="{DynamicResource AppTextSecondaryBrush}"
                         FontFamily="Consolas, Courier New, monospace"
                         FontSize="{DynamicResource ConsoleOutputFontSize}"
                         Margin="{DynamicResource ConsoleOutputMargin}" TextWrapping="Wrap" />
            </ScrollViewer>
          </Border>
        </TabItem>
        <TabItem Header="诊断">
          <Border Background="{DynamicResource AppPanelBrush}">
            <ScrollViewer>
              <ItemsControl ItemsSource="{Binding Diagnostics}" Margin="{DynamicResource CardPadding}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="core:Diagnostic">
                    <Border Background="{Binding Severity, Converter={x:Static vm:SeverityToBrushConverter.Instance}}"
                            CornerRadius="{DynamicResource CardCornerRadius}"
                            Padding="{DynamicResource CardPadding}"
                            Margin="{DynamicResource CardMargin}"
                            BoxShadow="0 1 4 0 #20000000"
                            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1">
                      <StackPanel Spacing="4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                          <TextBlock Text="{Binding ErrorCode, StringFormat='[{0}]'}" Foreground="{DynamicResource AppSyntaxErrorBrush}" FontWeight="Bold" IsVisible="{Binding ErrorCode, Converter={x:Static vm:IntToBoolConverter.Instance}}" />
                          <TextBlock Text="{Binding Line, StringFormat='第{0}行'}" Foreground="{DynamicResource AppSyntaxKeywordBrush}" />
                          <TextBlock Text="{Binding Severity, StringFormat='严重度:{0}'}" Foreground="{DynamicResource AppSyntaxSeverityBrush}" />
                        </StackPanel>
                        <Border Background="{DynamicResource AppBackgroundBrush}" CornerRadius="{DynamicResource CardInnerCornerRadius}" Padding="{DynamicResource CardInnerPadding}" IsVisible="{Binding CodeSnippet, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                          <TextBlock Text="{Binding CodeSnippet}" Foreground="{DynamicResource AppTextBrush}" FontFamily="Consolas, Courier New, monospace" TextWrapping="NoWrap" />
                        </Border>
                        <TextBlock Text="{Binding Message}" Foreground="{DynamicResource AppTextBrush}" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding FixSuggestion, StringFormat='💡 {0}'}" Foreground="{DynamicResource AppSyntaxValueBrush}"
                                   TextWrapping="Wrap" IsVisible="{Binding FixSuggestion, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        <Button Content="应用修复"
                                IsVisible="{Binding FixSuggestion, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                                Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).ApplyFixCommand}"
                                CommandParameter="{Binding}"
                                Background="#0A84FF" Foreground="#FFFFFF"
                                Padding="8,4" CornerRadius="6"
                                FontSize="12">
                          <Button.Styles>
                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                              <Setter Property="Background" Value="#1E90FF" />
                            </Style>
                            <Style Selector="Button:pressed /template/ ContentPresenter">
                              <Setter Property="Background" Value="#005BB5" />
                            </Style>
                          </Button.Styles>
                        </Button>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Border>
        </TabItem>
        <TabItem Header="算法">
          <Border Background="{DynamicResource AppPanelBrush}">
            <ScrollViewer>
              <StackPanel>
                <ItemsControl ItemsSource="{Binding AlgorithmMatches}" Margin="{DynamicResource CardPadding}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="core:AlgorithmMatch">
                      <Border Background="{DynamicResource AppAlgorithmBgBrush}" CornerRadius="{DynamicResource CardCornerRadius}" Padding="{DynamicResource CardPadding}" Margin="{DynamicResource CardMargin}">
                        <StackPanel Spacing="4">
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource AppSyntaxValueBrush}" FontWeight="Bold" />
                            <TextBlock Text="{Binding Confidence, StringFormat='置信度:{0}%'}" Foreground="{DynamicResource AppTextMutedBrush}" />
                          </StackPanel>
                          <TextBlock Text="{Binding Suggestion}" Foreground="{DynamicResource AppTextBrush}" TextWrapping="Wrap" />
                          <Button Content="🔍 验证算法"
                                  Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).ValidateAlgorithmCommand}"
                                  CommandParameter="{Binding}"
                                  Background="#28a745" Foreground="#FFFFFF"
                                  Padding="8,4" CornerRadius="6"
                                  FontSize="12" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </ScrollViewer>
          </Border>
        </TabItem>
        <TabItem Header="输入">
          <Border Background="{DynamicResource AppPanelBrush}">
            <Grid RowDefinitions="Auto, *" Margin="{DynamicResource ConsoleOutputMargin}">
              <TextBlock Grid.Row="0" Text="程序输入数据（每行一个值，供 scanf 使用）" 
                         Foreground="{DynamicResource AppTextMutedBrush}" FontSize="11" Margin="0,0,0,4" />
              <TextBox Grid.Row="1" 
                       Text="{Binding InputText, Mode=TwoWay}"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       FontFamily="Consolas, Courier New, monospace"
                       FontSize="{DynamicResource ConsoleOutputFontSize}"
                       Background="{DynamicResource AppBackgroundBrush}"
                       Foreground="{DynamicResource AppTextBrush}" />
            </Grid>
          </Border>
        </TabItem>
      </TabControl>
    </Grid>

    <!-- 右侧调试面板：仅桌面显示 -->
    <Grid Grid.Column="1" x:Name="DesktopDebugPanel"
          RowDefinitions="Auto, *, Auto" Background="{DynamicResource AppBackgroundBrush}" Margin="{DynamicResource DebugPanelMargin}"
          Width="{DynamicResource DebugPanelWidth}"
          IsVisible="{Binding Responsive.IsDesktop}">
      <TextBlock Grid.Row="0" Text="🔍 调试面板" Foreground="{DynamicResource AppTextSecondaryBrush}" FontWeight="Bold" 
                 Margin="{DynamicResource DebugPanelHeaderMargin}" FontSize="{DynamicResource DebugPanelHeaderFontSize}" />
      <TabControl Grid.Row="1" Background="{DynamicResource AppPanelBrush}">
        <TabItem Header="📞 调用栈" Background="{DynamicResource AppPanelBrush}" Foreground="{DynamicResource AppTextSecondaryBrush}">
          <Border Background="{DynamicResource AppPanelBrush}">
            <ScrollViewer>
              <ItemsControl ItemsSource="{Binding CallStackFrames}" Margin="4">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:CallStackFrame">
                    <Border Background="{DynamicResource AppCardBrush}" CornerRadius="{DynamicResource DebugItemCornerRadius}" Padding="{DynamicResource DebugItemPadding}" Margin="{DynamicResource DebugItemMargin}"
                            PointerPressed="OnCallStackFramePressed"
                            Tag="{Binding}">
                      <StackPanel Spacing="2">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                          <TextBlock Text="{Binding IsCurrentFrame, StringFormat='{}{0:➤ }'}" Foreground="{DynamicResource AppSyntaxValueBrush}" FontSize="{DynamicResource DebugItemFontSize}" />
                          <TextBlock Text="{Binding FunctionName}" Foreground="{DynamicResource AppSyntaxKeywordBrush}" FontWeight="Bold" />
                        </StackPanel>
                        <TextBlock Text="{Binding ReturnLine, StringFormat='返回行: {0}'}" 
                                   Foreground="{DynamicResource AppTextMutedBrush}" FontSize="{DynamicResource DebugItemDetailFontSize}" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Border>
        </TabItem>
        <TabItem Header="🔍 Watch" Background="{DynamicResource AppPanelBrush}" Foreground="{DynamicResource AppTextSecondaryBrush}">
          <Border Background="{DynamicResource AppPanelBrush}">
            <Grid RowDefinitions="Auto, *">
              <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="4" Margin="4">
                <TextBox Width="140" Watermark="表达式 (如 arr[2])" 
                         Text="{Binding NewWatchExpression}" VerticalAlignment="Center" />
                <Button Content="+" Command="{Binding AddWatchExpressionCommand}" 
                        VerticalAlignment="Center" Padding="8,4" />
              </StackPanel>
              <ScrollViewer Grid.Row="1">
                <ItemsControl ItemsSource="{Binding WatchExpressions}" Margin="4">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:WatchExpression">
                      <Border Background="{DynamicResource AppCardBrush}" CornerRadius="{DynamicResource DebugItemCornerRadius}" Padding="{DynamicResource DebugItemPadding}" Margin="{DynamicResource DebugItemMargin}">
                        <Grid ColumnDefinitions="*, Auto, Auto">
                          <TextBlock Grid.Column="0" Text="{Binding Expression}" Foreground="{DynamicResource AppSyntaxKeywordBrush}" FontSize="{DynamicResource DebugItemFontSize}" />
                          <TextBlock Grid.Column="1" Text="{Binding Value}" Foreground="{DynamicResource AppSyntaxValueBrush}" FontSize="{DynamicResource DebugItemFontSize}" Margin="8,0" />
                          <Button Grid.Column="2" Content="×" Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).RemoveWatchExpressionCommand}" 
                                  CommandParameter="{Binding}" Padding="4,0" FontSize="{DynamicResource DebugItemFontSize}"
                                  Background="Transparent" Foreground="{DynamicResource AppTextMutedBrush}" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Grid>
          </Border>
        </TabItem>
        <TabItem Header="📊 变量" Background="{DynamicResource AppPanelBrush}" Foreground="{DynamicResource AppTextSecondaryBrush}">
          <Border Background="{DynamicResource AppPanelBrush}">
            <ScrollViewer>
              <ItemsControl ItemsSource="{Binding Variables}" Margin="4">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="core:VariableSnapshot">
                    <Border Background="{DynamicResource AppCardBrush}" CornerRadius="{DynamicResource DebugItemCornerRadius}" Padding="{DynamicResource DebugItemPadding}" Margin="{DynamicResource DebugItemMargin}">
                      <StackPanel Spacing="2">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                          <TextBlock Text="{Binding Name}" Foreground="{DynamicResource AppSyntaxKeywordBrush}" FontWeight="Bold" Width="80" />
                          <TextBlock Text="{Binding Value}" Foreground="{DynamicResource AppSyntaxValueBrush}" Width="60" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                          <TextBlock Text="{Binding Address, StringFormat='0x{0:X4}'}" Foreground="{DynamicResource AppTextMutedBrush}" FontSize="{DynamicResource DebugItemDetailFontSize}" Width="80" />
                          <TextBlock Text="{Binding IsLocal, StringFormat='局部:{0}'}" Foreground="{DynamicResource AppTextMutedBrush}" FontSize="{DynamicResource DebugItemDetailFontSize}" Width="50" />
                          <TextBlock Text="{Binding IsArray, StringFormat='数组:{0}'}" Foreground="{DynamicResource AppTextMutedBrush}" FontSize="{DynamicResource DebugItemDetailFontSize}" />
                        </StackPanel>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Border>
        </TabItem>
        <TabItem Header="🧠 内存" Background="{DynamicResource AppPanelBrush}" Foreground="{DynamicResource AppTextSecondaryBrush}">
          <Border Background="{DynamicResource AppPanelBrush}">
            <ScrollViewer>
              <StackPanel Spacing="4" Margin="4">
                <TextBlock Text="📦 内存区域" Foreground="{DynamicResource AppTextSecondaryBrush}" FontWeight="Bold" FontSize="{DynamicResource CardTitleFontSize}" />
                <ItemsControl ItemsSource="{Binding MemoryRegions}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,1">
                        <TextBlock Text="{Binding Address, StringFormat='0x{0:X4}'}" Foreground="{DynamicResource AppSyntaxKeywordBrush}" Width="60" FontSize="11" />
                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource AppSyntaxFunctionBrush}" Width="80" FontSize="11" />
                        <TextBlock Text="{Binding Value}" Foreground="{DynamicResource AppSyntaxValueBrush}" Width="50" FontSize="11" />
                        <TextBlock Text="{Binding IsFreed, StringFormat='已释放:{0}'}" Foreground="{DynamicResource AppTextMutedBrush}" Width="60" FontSize="11" />
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </ScrollViewer>
          </Border>
        </TabItem>
        <TabItem Header="📊 数组" Background="{DynamicResource AppPanelBrush}" Foreground="{DynamicResource AppTextSecondaryBrush}">
          <Border Background="{DynamicResource AppPanelBrush}">
            <ScrollViewer>
              <ItemsControl ItemsSource="{Binding ArrayVisualizations}" Margin="4">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:ArrayVisualization">
                    <Border Background="{DynamicResource AppCardBrush}" CornerRadius="{DynamicResource DebugItemCornerRadius}" Padding="{DynamicResource CardPadding}" Margin="{DynamicResource CardMargin}">
                      <StackPanel Spacing="6">
                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource AppSyntaxKeywordBrush}" FontWeight="Bold" />
                        <Border Background="{DynamicResource AppBackgroundBrush}" CornerRadius="{DynamicResource CardInnerCornerRadius}" Padding="{DynamicResource CardInnerPadding}" Height="120">
                          <ItemsControl ItemsSource="{Binding Elements}">
                            <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Bottom" />
                              </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate x:DataType="vm:ArrayElementVisual">
                                <Grid VerticalAlignment="Bottom" Width="32">
                                  <Border Background="{Binding BackgroundColor}"
                                          BorderBrush="{Binding BorderColor}"
                                          BorderThickness="1"
                                          CornerRadius="2"
                                          Height="{Binding HeightPercent}"
                                          VerticalAlignment="Bottom">
                                    <TextBlock Text="{Binding Value}" Foreground="{DynamicResource AppTextBrush}" FontSize="9"
                                               HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,2" />
                                  </Border>
                                </Grid>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </Border>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Border>
        </TabItem>
        <TabItem Header="🔗 指针" Background="{DynamicResource AppPanelBrush}" Foreground="{DynamicResource AppTextSecondaryBrush}">
          <Border Background="{DynamicResource AppPanelBrush}">
            <ScrollViewer>
              <ItemsControl ItemsSource="{Binding PointerVariables}" Margin="4">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:PointerViewModel">
                    <Border Background="{DynamicResource AppCardBrush}" CornerRadius="{DynamicResource DebugItemCornerRadius}" Padding="{DynamicResource DebugItemPadding}" Margin="{DynamicResource DebugItemMargin}">
                      <StackPanel Spacing="2">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                          <TextBlock Text="{Binding VariableName}" Foreground="{DynamicResource AppSyntaxFunctionBrush}" FontWeight="Bold" Width="80" />
                          <TextBlock Text="→" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                          <TextBlock Text="{Binding TargetName}" Foreground="{DynamicResource AppSyntaxKeywordBrush}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                          <TextBlock Text="{Binding Address, StringFormat='0x{0:X4}'}" Foreground="{DynamicResource AppTextMutedBrush}" FontSize="{DynamicResource DebugItemDetailFontSize}" Width="80" />
                          <TextBlock Text="{Binding TargetAddress, StringFormat='目标:0x{0:X4}'}" Foreground="{DynamicResource AppTextMutedBrush}" FontSize="{DynamicResource DebugItemDetailFontSize}" />
                        </StackPanel>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Border>
        </TabItem>
        <TabItem Header="🧬 链表" Background="{DynamicResource AppPanelBrush}" Foreground="{DynamicResource AppTextSecondaryBrush}"
                 IsVisible="{Binding GraphNodes.Count, Converter={x:Static vm:IntToBoolConverter.Instance}}">
          <Border Background="{DynamicResource AppPanelBrush}">
            <views:GraphCanvas Nodes="{Binding GraphNodes}" Height="200" />
          </Border>
        </TabItem>
        <TabItem Header="📚 知识" Background="{DynamicResource AppPanelBrush}" Foreground="{DynamicResource AppTextSecondaryBrush}"
                 IsVisible="{Binding CurrentKnowledgeCard.IsVisible}">
          <Border Background="{DynamicResource AppPanelBrush}">
            <ScrollViewer>
              <StackPanel Spacing="8" Margin="8" IsVisible="{Binding CurrentKnowledgeCard.IsVisible}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="{Binding CurrentKnowledgeCard.Emoji}" FontSize="{DynamicResource DebugPanelHeaderFontSize}" />
                  <TextBlock Text="{Binding CurrentKnowledgeCard.Title}" Foreground="{DynamicResource AppSyntaxKeywordBrush}" FontWeight="Bold" FontSize="{DynamicResource DebugPanelHeaderFontSize}" />
                </StackPanel>
                <Border Background="{DynamicResource AppBackgroundBrush}" CornerRadius="{DynamicResource CardInnerCornerRadius}" Padding="{DynamicResource CardInnerPadding}"
                        IsVisible="{Binding CurrentKnowledgeCard.CodeSnippet, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                  <TextBlock Text="{Binding CurrentKnowledgeCard.CodeSnippet}" Foreground="{DynamicResource AppTextBrush}"
                             FontFamily="Consolas, Courier New, monospace" TextWrapping="Wrap" />
                </Border>
                <TextBlock Text="{Binding CurrentKnowledgeCard.PlainExplanation}" Foreground="{DynamicResource AppTextBrush}" TextWrapping="Wrap" />
                <StackPanel Spacing="4"
                            IsVisible="{Binding CurrentKnowledgeCard.WrongCode, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                  <TextBlock Text="❌ 错误写法" Foreground="{DynamicResource AppSyntaxErrorBrush}" FontSize="{DynamicResource CardTitleFontSize}" />
                  <Border Background="{DynamicResource AppWrongCodeBgBrush}" CornerRadius="{DynamicResource CardInnerCornerRadius}" Padding="{DynamicResource CardInnerPadding}">
                    <TextBlock Text="{Binding CurrentKnowledgeCard.WrongCode}" Foreground="{DynamicResource AppTextBrush}"
                               FontFamily="Consolas, Courier New, monospace" TextWrapping="Wrap" />
                  </Border>
                  <TextBlock Text="✅ 正确写法" Foreground="{DynamicResource AppSyntaxValueBrush}" FontSize="{DynamicResource CardTitleFontSize}" />
                  <Border Background="{DynamicResource AppCorrectCodeBgBrush}" CornerRadius="{DynamicResource CardInnerCornerRadius}" Padding="{DynamicResource CardInnerPadding}">
                    <TextBlock Text="{Binding CurrentKnowledgeCard.CorrectCode}" Foreground="{DynamicResource AppTextBrush}"
                               FontFamily="Consolas, Courier New, monospace" TextWrapping="Wrap" />
                  </Border>
                </StackPanel>
                <TextBlock Text="{Binding CurrentKnowledgeCard.MemoryAnimationDescription, StringFormat='🎬 内存动画：{0}'}"
                           Foreground="{DynamicResource AppSyntaxWarningBrush}" TextWrapping="Wrap"
                           IsVisible="{Binding CurrentKnowledgeCard.MemoryAnimationDescription, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                <TextBlock Text="{Binding CurrentKnowledgeCard.Exercise, StringFormat='📝 {0}'}"
                           Foreground="{DynamicResource AppSyntaxKeywordBrush}" TextWrapping="Wrap"
                           IsVisible="{Binding CurrentKnowledgeCard.Exercise, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
              </StackPanel>
            </ScrollViewer>
          </Border>
        </TabItem>
      </TabControl>
      <Border Grid.Row="2" Background="{DynamicResource AppCardBrush}" Padding="{DynamicResource CardPadding}" Margin="{DynamicResource BottomPanelMargin}">
        <TextBlock Text="{Binding StepStatusText}" Foreground="{DynamicResource AppSyntaxKeywordBrush}" FontSize="{DynamicResource DebugItemFontSize}" />
      </Border>
    </Grid>

    <!-- ===== 移动端模态面板覆盖层 ===== -->
    <Grid Grid.Column="0" Grid.ColumnSpan="2"
          IsVisible="{Binding Responsive.IsDesktop, Converter={x:Static BoolConverters.Not}}"
          Background="Transparent"
          IsHitTestVisible="False">
      <Border x:Name="ModalBackdrop"
              Background="#CC000000"
              IsVisible="False"
              IsHitTestVisible="True"
              PointerPressed="OnModalBackdropPressed">
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{DynamicResource AppBackgroundBrush}" CornerRadius="{DynamicResource ModalCornerRadius}" Padding="0"
                Width="{DynamicResource ModalWidth}" Height="{DynamicResource ModalHeight}"
                PointerPressed="OnModalContentPressed">
          <Grid RowDefinitions="Auto, *">
            <Button Grid.Row="0" HorizontalAlignment="Right" Margin="{DynamicResource ModalCloseBtnMargin}"
                    Content="✕" FontSize="{DynamicResource ModalCloseBtnFontSize}" Foreground="{DynamicResource AppTextSecondaryBrush}"
                    Background="Transparent"
                    Click="OnCloseModalClick" />
            <TabControl Grid.Row="1" x:Name="MobileDebugTabs"
                        Background="{DynamicResource AppBackgroundBrush}" Padding="0">
              <TabControl.Styles>
                <Style Selector="TabItem">
                  <Setter Property="IsVisible" Value="False" />
                  <Setter Property="Height" Value="0" />
                  <Setter Property="Padding" Value="0" />
                  <Setter Property="Margin" Value="0" />
                </Style>
                <Style Selector="TabItem:selected">
                  <Setter Property="IsVisible" Value="False" />
                </Style>
              </TabControl.Styles>
              <!-- 调用栈 -->
              <TabItem>
                <Border Background="{DynamicResource AppPanelBrush}">
                  <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding CallStackFrames}" Margin="4">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:CallStackFrame">
                          <Border Background="{DynamicResource AppCardBrush}" CornerRadius="{DynamicResource DebugItemCornerRadius}" Padding="{DynamicResource DebugItemPadding}" Margin="{DynamicResource DebugItemMargin}"
                                  PointerPressed="OnCallStackFramePressed"
                                  Tag="{Binding}">
                            <StackPanel Spacing="2">
                              <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding IsCurrentFrame, StringFormat='{}{0:➤ }'}" Foreground="{DynamicResource AppSyntaxValueBrush}" FontSize="{DynamicResource DebugItemFontSize}" />
                                <TextBlock Text="{Binding FunctionName}" Foreground="{DynamicResource AppSyntaxKeywordBrush}" FontWeight="Bold" />
                              </StackPanel>
                              <TextBlock Text="{Binding ReturnLine, StringFormat='返回行: {0}'}" 
                                         Foreground="{DynamicResource AppTextMutedBrush}" FontSize="{DynamicResource DebugItemDetailFontSize}" />
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </Border>
              </TabItem>
              <!-- Watch -->
              <TabItem>
                <Border Background="{DynamicResource AppPanelBrush}">
                  <Grid RowDefinitions="Auto, *">
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="4" Margin="4">
                      <TextBox Width="140" Watermark="表达式 (如 arr[2])" 
                               Text="{Binding NewWatchExpression}" VerticalAlignment="Center" />
                      <Button Content="+" Command="{Binding AddWatchExpressionCommand}" 
                              VerticalAlignment="Center" Padding="8,4" />
                    </StackPanel>
                    <ScrollViewer Grid.Row="1">
                      <ItemsControl ItemsSource="{Binding WatchExpressions}" Margin="4">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:WatchExpression">
                            <Border Background="{DynamicResource AppCardBrush}" CornerRadius="3" Padding="6" Margin="0,2">
                              <Grid ColumnDefinitions="*, Auto, Auto">
                                <TextBlock Grid.Column="0" Text="{Binding Expression}" Foreground="{DynamicResource AppSyntaxKeywordBrush}" FontSize="{DynamicResource DebugItemFontSize}" />
                                <TextBlock Grid.Column="1" Text="{Binding Value}" Foreground="{DynamicResource AppSyntaxValueBrush}" FontSize="{DynamicResource DebugItemFontSize}" Margin="8,0" />
                                <Button Grid.Column="2" Content="×" Command="{Binding $parent[ItemsControl].((vm:MainViewModel)DataContext).RemoveWatchExpressionCommand}" 
                                        CommandParameter="{Binding}" Padding="4,0" FontSize="{DynamicResource DebugItemFontSize}"
                                        Background="Transparent" Foreground="{DynamicResource AppTextMutedBrush}" />
                              </Grid>
                            </Border>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </ScrollViewer>
                  </Grid>
                </Border>
              </TabItem>
              <!-- 变量 -->
              <TabItem>
                <Border Background="{DynamicResource AppPanelBrush}">
                  <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding Variables}" Margin="4">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="core:VariableSnapshot">
                          <Border Background="{DynamicResource AppCardBrush}" CornerRadius="{DynamicResource DebugItemCornerRadius}" Padding="{DynamicResource DebugItemPadding}" Margin="{DynamicResource DebugItemMargin}">
                            <StackPanel Spacing="2">
                              <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource AppSyntaxKeywordBrush}" FontWeight="Bold" Width="80" />
                                <TextBlock Text="{Binding Value}" Foreground="{DynamicResource AppSyntaxValueBrush}" Width="60" />
                              </StackPanel>
                              <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding Address, StringFormat='0x{0:X4}'}" Foreground="{DynamicResource AppTextMutedBrush}" FontSize="{DynamicResource DebugItemDetailFontSize}" Width="80" />
                                <TextBlock Text="{Binding IsLocal, StringFormat='局部:{0}'}" Foreground="{DynamicResource AppTextMutedBrush}" FontSize="{DynamicResource DebugItemDetailFontSize}" Width="50" />
                                <TextBlock Text="{Binding IsArray, StringFormat='数组:{0}'}" Foreground="{DynamicResource AppTextMutedBrush}" FontSize="{DynamicResource DebugItemDetailFontSize}" />
                              </StackPanel>
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </Border>
              </TabItem>
              <!-- 内存 -->
              <TabItem>
                <Border Background="{DynamicResource AppPanelBrush}">
                  <ScrollViewer>
                    <StackPanel Spacing="4" Margin="{DynamicResource DebugItemMargin}">
                      <TextBlock Text="📦 内存区域" Foreground="{DynamicResource AppTextSecondaryBrush}" FontWeight="Bold" FontSize="{DynamicResource CardTitleFontSize}" />
                      <ItemsControl ItemsSource="{Binding MemoryRegions}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,1">
                              <TextBlock Text="{Binding Address, StringFormat='0x{0:X4}'}" Foreground="{DynamicResource AppSyntaxKeywordBrush}" Width="60" FontSize="{DynamicResource DebugItemDetailFontSize}" />
                              <TextBlock Text="{Binding Name}" Foreground="{DynamicResource AppSyntaxFunctionBrush}" Width="80" FontSize="{DynamicResource DebugItemDetailFontSize}" />
                              <TextBlock Text="{Binding Value}" Foreground="{DynamicResource AppSyntaxValueBrush}" Width="50" FontSize="{DynamicResource DebugItemDetailFontSize}" />
                              <TextBlock Text="{Binding IsFreed, StringFormat='已释放:{0}'}" Foreground="{DynamicResource AppTextMutedBrush}" Width="60" FontSize="{DynamicResource DebugItemDetailFontSize}" />
                            </StackPanel>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </ScrollViewer>
                </Border>
              </TabItem>
              <!-- 数组 -->
              <TabItem>
                <Border Background="{DynamicResource AppPanelBrush}">
                  <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding ArrayVisualizations}" Margin="4">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ArrayVisualization">
                          <Border Background="{DynamicResource AppCardBrush}" CornerRadius="{DynamicResource DebugItemCornerRadius}" Padding="{DynamicResource CardPadding}" Margin="{DynamicResource CardMargin}">
                            <StackPanel Spacing="6">
                              <TextBlock Text="{Binding Name}" Foreground="{DynamicResource AppSyntaxKeywordBrush}" FontWeight="Bold" />
                              <Border Background="{DynamicResource AppBackgroundBrush}" CornerRadius="{DynamicResource CardInnerCornerRadius}" Padding="{DynamicResource CardInnerPadding}" Height="120">
                                <ItemsControl ItemsSource="{Binding Elements}">
                                  <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                      <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Bottom" />
                                    </ItemsPanelTemplate>
                                  </ItemsControl.ItemsPanel>
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ArrayElementVisual">
                                      <Grid VerticalAlignment="Bottom" Width="32">
                                        <Border Background="{Binding BackgroundColor}"
                                                BorderBrush="{Binding BorderColor}"
                                                BorderThickness="1"
                                                CornerRadius="2"
                                                Height="{Binding HeightPercent}"
                                                VerticalAlignment="Bottom">
                                          <TextBlock Text="{Binding Value}" Foreground="{DynamicResource AppTextBrush}" FontSize="9"
                                                     HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,2" />
                                        </Border>
                                      </Grid>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </Border>
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </Border>
              </TabItem>
              <!-- 指针 -->
              <TabItem>
                <Border Background="{DynamicResource AppPanelBrush}">
                  <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding PointerVariables}" Margin="4">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:PointerViewModel">
                          <Border Background="{DynamicResource AppCardBrush}" CornerRadius="{DynamicResource DebugItemCornerRadius}" Padding="{DynamicResource DebugItemPadding}" Margin="{DynamicResource DebugItemMargin}">
                            <StackPanel Spacing="2">
                              <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding VariableName}" Foreground="{DynamicResource AppSyntaxFunctionBrush}" FontWeight="Bold" Width="80" />
                                <TextBlock Text="→" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                                <TextBlock Text="{Binding TargetName}" Foreground="{DynamicResource AppSyntaxKeywordBrush}" />
                              </StackPanel>
                              <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Text="{Binding Address, StringFormat='0x{0:X4}'}" Foreground="{DynamicResource AppTextMutedBrush}" FontSize="{DynamicResource DebugItemDetailFontSize}" Width="80" />
                                <TextBlock Text="{Binding TargetAddress, StringFormat='目标:0x{0:X4}'}" Foreground="{DynamicResource AppTextMutedBrush}" FontSize="{DynamicResource DebugItemDetailFontSize}" />
                              </StackPanel>
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </ScrollViewer>
                </Border>
              </TabItem>
              <!-- 链表 -->
              <TabItem IsVisible="{Binding GraphNodes.Count, Converter={x:Static vm:IntToBoolConverter.Instance}}">
                <TabItem.Header>
                  <TextBlock Text="🧬 链表" Foreground="{DynamicResource AppTextSecondaryBrush}" />
                </TabItem.Header>
                <Border Background="{DynamicResource AppPanelBrush}">
                  <views:GraphCanvas Nodes="{Binding GraphNodes}" Height="200" />
                </Border>
              </TabItem>
              <!-- 知识 -->
              <TabItem IsVisible="{Binding CurrentKnowledgeCard.IsVisible}">
                <Border Background="{DynamicResource AppPanelBrush}">
                  <ScrollViewer>
                    <StackPanel Spacing="8" Margin="8" IsVisible="{Binding CurrentKnowledgeCard.IsVisible}">
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock Text="{Binding CurrentKnowledgeCard.Emoji}" FontSize="{DynamicResource DebugPanelHeaderFontSize}" />
                        <TextBlock Text="{Binding CurrentKnowledgeCard.Title}" Foreground="{DynamicResource AppSyntaxKeywordBrush}" FontWeight="Bold" FontSize="{DynamicResource DebugPanelHeaderFontSize}" />
                      </StackPanel>
                      <Border Background="{DynamicResource AppBackgroundBrush}" CornerRadius="{DynamicResource CardInnerCornerRadius}" Padding="{DynamicResource CardInnerPadding}"
                              IsVisible="{Binding CurrentKnowledgeCard.CodeSnippet, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Text="{Binding CurrentKnowledgeCard.CodeSnippet}" Foreground="{DynamicResource AppTextBrush}"
                                   FontFamily="Consolas, Courier New, monospace" TextWrapping="Wrap" />
                      </Border>
                      <TextBlock Text="{Binding CurrentKnowledgeCard.PlainExplanation}" Foreground="{DynamicResource AppTextBrush}" TextWrapping="Wrap" />
                      <StackPanel Spacing="4"
                                  IsVisible="{Binding CurrentKnowledgeCard.WrongCode, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                        <TextBlock Text="❌ 错误写法" Foreground="{DynamicResource AppSyntaxErrorBrush}" FontSize="{DynamicResource CardTitleFontSize}" />
                        <Border Background="{DynamicResource AppWrongCodeBgBrush}" CornerRadius="{DynamicResource CardInnerCornerRadius}" Padding="{DynamicResource CardInnerPadding}">
                          <TextBlock Text="{Binding CurrentKnowledgeCard.WrongCode}" Foreground="{DynamicResource AppTextBrush}"
                                     FontFamily="Consolas, Courier New, monospace" TextWrapping="Wrap" />
                        </Border>
                        <TextBlock Text="✅ 正确写法" Foreground="{DynamicResource AppSyntaxValueBrush}" FontSize="{DynamicResource CardTitleFontSize}" />
                        <Border Background="{DynamicResource AppCorrectCodeBgBrush}" CornerRadius="{DynamicResource CardInnerCornerRadius}" Padding="{DynamicResource CardInnerPadding}">
                          <TextBlock Text="{Binding CurrentKnowledgeCard.CorrectCode}" Foreground="{DynamicResource AppTextBrush}"
                                     FontFamily="Consolas, Courier New, monospace" TextWrapping="Wrap" />
                        </Border>
                      </StackPanel>
                      <TextBlock Text="{Binding CurrentKnowledgeCard.MemoryAnimationDescription, StringFormat='🎬 内存动画：{0}'}"
                                 Foreground="{DynamicResource AppSyntaxWarningBrush}" TextWrapping="Wrap"
                                 IsVisible="{Binding CurrentKnowledgeCard.MemoryAnimationDescription, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                      <TextBlock Text="{Binding CurrentKnowledgeCard.Exercise, StringFormat='📝 {0}'}"
                                 Foreground="{DynamicResource AppSyntaxKeywordBrush}" TextWrapping="Wrap"
                                 IsVisible="{Binding CurrentKnowledgeCard.Exercise, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    </StackPanel>
                  </ScrollViewer>
                </Border>
              </TabItem>
            </TabControl>
          </Grid>
        </Border>
      </Border>
    </Grid>

    <!-- ===== 移动端悬浮球覆盖层 ===== -->
    <Grid Grid.Column="0" Grid.ColumnSpan="2"
          IsVisible="{Binding Responsive.IsDesktop, Converter={x:Static BoolConverters.Not}}"
          HorizontalAlignment="Right" VerticalAlignment="Bottom"
          Width="{DynamicResource FabAreaWidth}" Height="{DynamicResource FabAreaHeight}">
      <Canvas HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
              ClipToBounds="False"
              x:Name="FabCanvas">
        <!-- 扇形按钮：毛玻璃质感 + 微妙边框 -->
        <Border x:Name="FanCallStackBorder" Width="{DynamicResource FanBtnSize}" Height="{DynamicResource FanBtnSize}" CornerRadius="{DynamicResource FanBtnCornerRadius}"
                Background="{DynamicResource AppFanBrush}" BorderBrush="{DynamicResource AppFanBorderBrush}" BorderThickness="1"
                BoxShadow="0 2 6 0 #40000000"
                Opacity="0" IsHitTestVisible="False">
          <Button Width="{DynamicResource FanBtnSize}" Height="{DynamicResource FanBtnSize}" CornerRadius="{DynamicResource FanBtnCornerRadius}"
                  Background="Transparent" Foreground="{DynamicResource AppFanTextBrush}" Content="栈" FontSize="{DynamicResource FanBtnFontSize}"
                  HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                  Click="OnFanCallStackClick" />
        </Border>
        <Border x:Name="FanWatchBorder" Width="{DynamicResource FanBtnSize}" Height="{DynamicResource FanBtnSize}" CornerRadius="{DynamicResource FanBtnCornerRadius}"
                Background="{DynamicResource AppFanBrush}" BorderBrush="{DynamicResource AppFanBorderBrush}" BorderThickness="1"
                BoxShadow="0 2 6 0 #40000000"
                Opacity="0" IsHitTestVisible="False">
          <Button Width="{DynamicResource FanBtnSize}" Height="{DynamicResource FanBtnSize}" CornerRadius="{DynamicResource FanBtnCornerRadius}"
                  Background="Transparent" Foreground="{DynamicResource AppFanTextBrush}" Content="表" FontSize="{DynamicResource FanBtnFontSize}"
                  HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                  Click="OnFanWatchClick" />
        </Border>
        <Border x:Name="FanVariablesBorder" Width="{DynamicResource FanBtnSize}" Height="{DynamicResource FanBtnSize}" CornerRadius="{DynamicResource FanBtnCornerRadius}"
                Background="{DynamicResource AppFanBrush}" BorderBrush="{DynamicResource AppFanBorderBrush}" BorderThickness="1"
                BoxShadow="0 2 6 0 #40000000"
                Opacity="0" IsHitTestVisible="False">
          <Button Width="{DynamicResource FanBtnSize}" Height="{DynamicResource FanBtnSize}" CornerRadius="{DynamicResource FanBtnCornerRadius}"
                  Background="Transparent" Foreground="{DynamicResource AppFanTextBrush}" Content="变" FontSize="{DynamicResource FanBtnFontSize}"
                  HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                  Click="OnFanVariablesClick" />
        </Border>
        <Border x:Name="FanMemoryBorder" Width="{DynamicResource FanBtnSize}" Height="{DynamicResource FanBtnSize}" CornerRadius="{DynamicResource FanBtnCornerRadius}"
                Background="{DynamicResource AppFanBrush}" BorderBrush="{DynamicResource AppFanBorderBrush}" BorderThickness="1"
                BoxShadow="0 2 6 0 #40000000"
                Opacity="0" IsHitTestVisible="False">
          <Button Width="{DynamicResource FanBtnSize}" Height="{DynamicResource FanBtnSize}" CornerRadius="{DynamicResource FanBtnCornerRadius}"
                  Background="Transparent" Foreground="{DynamicResource AppFanTextBrush}" Content="存" FontSize="{DynamicResource FanBtnFontSize}"
                  HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                  Click="OnFanMemoryClick" />
        </Border>
        <Border x:Name="FanArrayBorder" Width="{DynamicResource FanBtnSize}" Height="{DynamicResource FanBtnSize}" CornerRadius="{DynamicResource FanBtnCornerRadius}"
                Background="{DynamicResource AppFanBrush}" BorderBrush="{DynamicResource AppFanBorderBrush}" BorderThickness="1"
                BoxShadow="0 2 6 0 #40000000"
                Opacity="0" IsHitTestVisible="False">
          <Button Width="{DynamicResource FanBtnSize}" Height="{DynamicResource FanBtnSize}" CornerRadius="{DynamicResource FanBtnCornerRadius}"
                  Background="Transparent" Foreground="{DynamicResource AppFanTextBrush}" Content="组" FontSize="{DynamicResource FanBtnFontSize}"
                  HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                  Click="OnFanArrayClick" />
        </Border>
        <Border x:Name="FanPointerBorder" Width="{DynamicResource FanBtnSize}" Height="{DynamicResource FanBtnSize}" CornerRadius="{DynamicResource FanBtnCornerRadius}"
                Background="{DynamicResource AppFanBrush}" BorderBrush="{DynamicResource AppFanBorderBrush}" BorderThickness="1"
                BoxShadow="0 2 6 0 #40000000"
                Opacity="0" IsHitTestVisible="False">
          <Button Width="{DynamicResource FanBtnSize}" Height="{DynamicResource FanBtnSize}" CornerRadius="{DynamicResource FanBtnCornerRadius}"
                  Background="Transparent" Foreground="{DynamicResource AppFanTextBrush}" Content="针" FontSize="{DynamicResource FanBtnFontSize}"
                  HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                  Click="OnFanPointerClick" />
        </Border>
        <Border x:Name="FanKnowledgeBorder" Width="{DynamicResource FanBtnSize}" Height="{DynamicResource FanBtnSize}" CornerRadius="{DynamicResource FanBtnCornerRadius}"
                Background="{DynamicResource AppFanBrush}" BorderBrush="{DynamicResource AppFanBorderBrush}" BorderThickness="1"
                BoxShadow="0 2 6 0 #40000000"
                Opacity="0" IsHitTestVisible="False">
          <Button Width="{DynamicResource FanBtnSize}" Height="{DynamicResource FanBtnSize}" CornerRadius="{DynamicResource FanBtnCornerRadius}"
                  Background="Transparent" Foreground="{DynamicResource AppFanTextBrush}" Content="知" FontSize="{DynamicResource FanBtnFontSize}"
                  HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                  Click="OnFanKnowledgeClick" />
        </Border>
        <!-- 主悬浮球：微渐变 + 阴影 -->
        <Border x:Name="FabButtonBorder" Width="{DynamicResource FabSize}" Height="{DynamicResource FabSize}" CornerRadius="{DynamicResource FabCornerRadius}"
                BoxShadow="0 3 10 0 #60000000"
                PointerPressed="OnFabPointerPressed"
                PointerMoved="OnFabPointerMoved"
                PointerReleased="OnFabPointerReleased">
          <Border.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
              <GradientStop Offset="0" Color="#0A84FF"/>
              <GradientStop Offset="1" Color="#005BB5"/>
            </LinearGradientBrush>
          </Border.Background>
          <Button x:Name="FabButton" Width="{DynamicResource FabSize}" Height="{DynamicResource FabSize}" CornerRadius="{DynamicResource FabCornerRadius}"
                  Background="Transparent" Foreground="White" Content="调" FontSize="{DynamicResource FabFontSize}"
                  HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                  IsHitTestVisible="False">
            <Button.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#0A84FF" />
                <GradientStop Offset="1" Color="#005BB5" />
              </LinearGradientBrush>
            </Button.Background>
          </Button>
        </Border>
      </Canvas>
    </Grid>
  </Grid>
</UserControl>
