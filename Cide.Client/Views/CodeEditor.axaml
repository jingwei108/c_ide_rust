<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="using:Cide.Client.Views"
             xmlns:vm="using:Cide.Client.ViewModels"
             xmlns:ae="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Cide.Client.Views.CodeEditor"
             x:DataType="views:CodeEditor">
  <Grid ColumnDefinitions="Auto, *">
    <!-- 行号区 -->
    <Border Grid.Column="0" Background="{DynamicResource AppCardBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="0,0,1,0"
            Width="{DynamicResource LineNumberWidth}">
      <ScrollViewer x:Name="LineNumberScrollViewer"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Hidden">
        <ItemsControl x:Name="LineNumbers" Margin="{DynamicResource LineNumberMargin}">
          <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="views:LineNumberItem">
              <Grid Background="{Binding BackgroundColor}" Margin="{DynamicResource LineNumberItemMargin}">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <!-- Breakpoint dot -->
                <Ellipse Grid.Column="0" Width="8" Height="8" Fill="{Binding CircleColor}"
                         VerticalAlignment="Center" Margin="{DynamicResource LineNumberEllipseMargin}"
                         IsVisible="{Binding IsBreakpoint}" />
                <TextBlock Grid.Column="1" Text="{Binding DisplayText}" Foreground="{Binding ForegroundColor}" FontSize="{DynamicResource LineNumberFontSize}"
                           HorizontalAlignment="Right" Padding="{DynamicResource LineNumberTextPadding}"
                           FontFamily="Consolas, Courier New, monospace" />
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Border>

    <!-- 代码编辑区 -->
    <Grid Grid.Column="1">
      <ae:TextEditor x:Name="Editor"
                     Background="{DynamicResource AppBackgroundBrush}" Foreground="{DynamicResource AppTextBrush}"
                     FontFamily="Consolas, Courier New, monospace"
                     FontSize="{DynamicResource EditorFontSize}"
                     ShowLineNumbers="False"
                     WordWrap="False"
                     Padding="{DynamicResource EditorPadding}">
        <ae:TextEditor.Options>
          <ae:TextEditorOptions ConvertTabsToSpaces="False" />
        </ae:TextEditor.Options>
      </ae:TextEditor>

      <!-- 模板智能提示浮层 -->
      <Popup x:Name="TemplatePopup"
             PlacementTarget="{Binding #Editor}"
             Placement="Bottom"
             IsOpen="False"
             HorizontalOffset="0"
             VerticalOffset="0">
        <Border Background="{DynamicResource AppPopupBrush}" BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="4" MinWidth="140">
          <ListBox x:Name="TemplateSuggestionList"
                   Background="Transparent"
                   BorderThickness="0"
                   Padding="0">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="vm:CodeTemplate">
                <Grid ColumnDefinitions="*, Auto">
                  <TextBlock Grid.Column="0" Text="{Binding DisplayName}" Foreground="{DynamicResource AppTextBrush}" Padding="4,2" />
                  <TextBlock Grid.Column="1" Text="{Binding Category}" Foreground="{DynamicResource AppTextMutedBrush}" FontSize="10" Padding="4,2" VerticalAlignment="Center" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Border>
      </Popup>
    </Grid>
  </Grid>
</UserControl>
