<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Cide.Client.ViewModels"
             x:Class="Cide.Client.Views.GraphCanvas"
             x:CompileBindings="False">
  <Canvas x:Name="RootCanvas" Background="#1E1E1E">
    <!-- Edges are added dynamically in code-behind -->
    <ItemsControl x:Name="NodeItemsControl" ItemsSource="{Binding Nodes}">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <Canvas />
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate x:DataType="vm:GraphNodeViewModel">
          <Border Width="64" Height="36"
                  Background="{Binding EffectiveBackgroundColor}"
                  BorderBrush="{Binding EffectiveBorderColor}"
                  BorderThickness="2"
                  CornerRadius="4"
                  Canvas.Left="{Binding X}"
                  Canvas.Top="{Binding Y}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
            <TextBlock Text="{Binding Label}"
                       Foreground="#FFFFFF"
                       FontSize="11"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>
  </Canvas>
</UserControl>
