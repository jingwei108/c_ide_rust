@page "/"
@inject MainViewModel VM
@implements IDisposable

<div class="cide-app @(VM.IsDarkMode ? "dark" : "light")">
    <div class="toolbar">
        <!-- 播放 / 停止 合一 -->
        <button class="btn-run" @onclick="VM.RunCodeAsync" disabled="@(!VM.CanRunCodeAsync)">▶</button>
        <button class="btn-stop" @onclick="VM.StopExecution" style="display:@(VM.IsRunning ? "flex" : "none")">■</button>
        <button class="btn-step" @onclick="VM.StepNext">⏭ 下一步</button>

        <div class="toolbar-slider">
            <input type="range" min="0" max="500" step="50" @bind="VM.ExecutionSpeed" />
        </div>

        <div class="toolbar-status">
            <span>@VM.StepStatusText</span>
            @if (VM.IsRunning)
            {
                <span class="running-indicator">●</span>
            }
        </div>

        <button class="btn-theme" @onclick="ToggleTheme">@(VM.IsDarkMode ? "亮" : "暗")</button>
    </div>

    <div class="editor-pane"
         @ontouchstart="OnTouchStart"
         @ontouchmove="OnTouchMove"
         @ontouchend="OnTouchEnd">
        <CodeMirrorEditor @ref="_editor" Code="@VM.SourceCode" CodeChanged="OnCodeChanged"
                          BreakpointToggled="OnBreakpointToggled"
                          IsDarkTheme="@VM.IsDarkMode" />
    </div>

    <!-- 模板快捷栏 -->
    <div class="template-bar">
        <div class="template-scroll">
            @foreach (var tmpl in VM.Templates)
            {
                <button class="template-chip" @onclick="() => InsertTemplate(tmpl.Code)">@tmpl.DisplayName</button>
            }
        </div>
    </div>

    <!-- 程序输入数据（供 scanf 使用） -->
    <div class="input-section">
        <div class="input-label">输入数据（每行一个值，供 scanf）</div>
        <textarea class="input-textarea" @bind="VM.InputText" rows="2"></textarea>
    </div>

    <div class="bottom-panel">
        <div class="tab-bar">
            <button class="tab @(VM.SelectedTabIndex == 0 ? "active" : "")" @onclick="() => VM.SelectedTabIndex = 0">输出</button>
            <button class="tab @(VM.SelectedTabIndex == 1 ? "active" : "")" @onclick="() => VM.SelectedTabIndex = 1">诊断</button>
            <button class="tab @(VM.SelectedTabIndex == 2 ? "active" : "")" @onclick="() => VM.SelectedTabIndex = 2">算法</button>
        </div>
        <div class="tab-content">
            @if (VM.SelectedTabIndex == 0)
            {
                <pre class="console-output">@(VM.ConsoleOutput ?? "等待执行...")</pre>
            }
            else if (VM.SelectedTabIndex == 1)
            {
                @if (VM.Diagnostics.Count == 0)
                {
                    <p class="empty-msg">无诊断信息</p>
                }
                else
                {
                    @foreach (var diag in VM.Diagnostics)
                    {
                        <div class="diag-item @(diag.Severity == 0 ? "error" : "warning")">
                            <div class="diag-header">
                                <span class="diag-severity">@(diag.Severity == 0 ? "错误" : "警告")</span>
                                <span class="diag-location">第 @diag.Line 行</span>
                                @if (diag.ErrorCode > 0)
                                {
                                    <span class="diag-code">[@diag.ErrorCode]</span>
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(diag.CodeSnippet))
                            {
                                <pre class="diag-snippet">@diag.CodeSnippet</pre>
                            }
                            <div class="diag-message">@diag.Message</div>
                            @if (!string.IsNullOrEmpty(diag.FixSuggestion))
                            {
                                <div class="diag-fix">
                                    <span>💡 @diag.FixSuggestion</span>
                                    <button @onclick="() => VM.ApplyFixCommand.Execute(diag)">应用修复</button>
                                </div>
                            }
                        </div>
                    }
                }
            }
            else if (VM.SelectedTabIndex == 2)
            {
                @if (VM.AlgorithmMatches.Count == 0)
                {
                    <p class="empty-msg">未检测到算法模式</p>
                }
                else
                {
                    <div class="algo-list">
                        @foreach (var match in VM.AlgorithmMatches)
                        {
                            <div class="algo-item">
                                <div class="algo-header">
                                    <span>@match.DisplayName</span>
                                    <span class="algo-confidence">置信度 @match.Confidence%</span>
                                </div>
                                <p>@match.Suggestion</p>
                                <button class="btn-validate" @onclick="() => VM.ValidateAlgorithmCommand.Execute(match)">🔍 验证算法</button>
                            </div>
                        }
                    </div>
                    @if (VM.CurrentValidationResult.HasValue)
                    {
                        var vr = VM.CurrentValidationResult.Value;
                        <div class="validation-result @(vr.Passed ? "pass" : "fail")">
                            <p>@vr.Message</p>
                            @if (!vr.Passed && vr.FailedCase.HasValue)
                            {
                                var fc = vr.FailedCase.Value;
                                <p class="val-case">用例: @fc.Description [@string.Join(", ", fc.InputArray)]</p>
                                @if (!string.IsNullOrEmpty(vr.ActualOutput))
                                {
                                    <p class="val-output">实际输出: @vr.ActualOutput</p>
                                }
                            }
                        </div>
                    }
                }
            }
        </div>
    </div>

</div>

<!-- Debug Modal -->
@if (_showDebugModal)
{
    <div class="debug-modal-backdrop" @onclick="CloseDebugModal">
        <div class="debug-modal-content"
             @onclick:stopPropagation
             @ontouchstart="OnModalTouchStart"
             @ontouchmove="OnModalTouchMove"
             @ontouchend="OnModalTouchEnd">
            <div class="debug-modal-drag-handle"></div>
            <div class="debug-modal-header">
                <span>@_debugModalTitle</span>
                <button @onclick="CloseDebugModal">✕</button>
            </div>
            <div class="debug-modal-body">
                @switch (_debugTabIndex)
                {
                    case 0:
                        @if (VM.CallStackFrames.Count == 0)
                        {
                            <p class="empty-msg">调用栈为空</p>
                        }
                        else
                        {
                            <div class="callstack-section">
                                @foreach (var frame in VM.CallStackFrames)
                                {
                                    <div class="callstack-frame @(frame.IsCurrentFrame ? "current" : "")"
                                         @onclick="() => VM.JumpToCallStackFrameCommand.Execute(frame)">
                                        <span>@frame.FunctionName</span>
                                        <span style="color:#888; margin-left:auto;">返回行 @frame.ReturnLine</span>
                                    </div>
                                }
                            </div>
                        }
                        break;
                    case 1:
                        @if (VM.WatchExpressions.Count == 0)
                        {
                            <p class="empty-msg">无监视表达式</p>
                        }
                        else
                        {
                            <div class="var-list">
                                @foreach (var expr in VM.WatchExpressions)
                                {
                                    <div class="var-item">
                                        <span class="var-name">@expr.Expression</span>
                                        <span class="var-value">@expr.Value</span>
                                    </div>
                                }
                            </div>
                        }
                        break;
                    case 2:
                        @if (VM.Variables.Count == 0)
                        {
                            <p class="empty-msg">无变量信息</p>
                        }
                        else
                        {
                            <div class="var-list">
                                <h4>局部变量</h4>
                                @foreach (var v in VM.Variables)
                                {
                                    <div class="var-item">
                                        <span class="var-name">@v.Name</span>
                                        <span class="var-type">@v.TypeName</span>
                                        <span class="var-value">@v.Value</span>
                                    </div>
                                }
                            </div>
                        }
                        break;
                    case 3:
                        @if (VM.MemoryRegions.Count == 0)
                        {
                            <p class="empty-msg">无内存信息</p>
                        }
                        else
                        {
                            <div class="mem-list">
                                @foreach (var mem in VM.MemoryRegions)
                                {
                                    <div class="mem-item @(mem.IsHeap ? "heap" : "stack") @(mem.IsFreed ? "freed" : "")">
                                        <span class="mem-addr">0x@mem.Address.ToString("X4")</span>
                                        <span class="mem-name">@mem.Name</span>
                                        <span class="mem-type">@mem.Type</span>
                                        <span class="mem-value">@mem.Value</span>
                                        @if (mem.IsHeap)
                                        {
                                            <span class="mem-tag heap-tag">堆</span>
                                        }
                                        @if (mem.IsFreed)
                                        {
                                            <span class="mem-tag freed-tag">已释放</span>
                                        }
                                    </div>
                                }
                            </div>
                        }
                        break;
                    case 4:
                        @if (VM.ArrayVisualizations.Count == 0)
                        {
                            <p class="empty-msg">无数组可视化</p>
                        }
                        else
                        {
                            @foreach (var arr in VM.ArrayVisualizations)
                            {
                                <div class="array-viz">
                                    <div class="array-name">@arr.Name (地址 0x@arr.BaseAddress.ToString("X4"))</div>
                                    <div class="array-bars">
                                        @foreach (var el in arr.Elements)
                                        {
                                            <div class="array-bar" style="height:@el.HeightPercent%; background:@el.BackgroundColor; border-color:@el.BorderColor;">
                                                @el.Value
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        }
                        break;
                    case 5:
                        @if (VM.PointerVariables.Count == 0)
                        {
                            <p class="empty-msg">无指针变量</p>
                        }
                        else
                        {
                            @foreach (var ptr in VM.PointerVariables)
                            {
                                <div class="pointer-item">
                                    <span>@ptr.VariableName</span>
                                    <span>→ 0x@ptr.TargetAddress.ToString("X4") (@ptr.TargetName)</span>
                                </div>
                            }
                        }
                        break;
                    case 6:
                        @if (VM.CurrentKnowledgeCard == null || !VM.CurrentKnowledgeCard.IsVisible)
                        {
                            <p class="empty-msg">无知识卡片</p>
                        }
                        else
                        {
                            <div class="knowledge-card">
                                <h4>@VM.CurrentKnowledgeCard.Emoji @VM.CurrentKnowledgeCard.Title</h4>
                                @if (!string.IsNullOrEmpty(VM.CurrentKnowledgeCard.CodeSnippet))
                                {
                                    <pre class="diag-snippet">@VM.CurrentKnowledgeCard.CodeSnippet</pre>
                                }
                                <p>@VM.CurrentKnowledgeCard.PlainExplanation</p>
                                @if (!string.IsNullOrEmpty(VM.CurrentKnowledgeCard.WrongCode))
                                {
                                    <div style="margin-top:8px; color:#ff6b6b; font-size:12px;">
                                        ❌ 错误写法: @VM.CurrentKnowledgeCard.WrongCode
                                    </div>
                                }
                            </div>
                        }
                        break;
                    case 7:
                        @if (VM.AlgorithmMatches.Count == 0)
                        {
                            <p class="empty-msg">未检测到算法模式</p>
                        }
                        else
                        {
                            <div class="algo-list">
                                @foreach (var match in VM.AlgorithmMatches)
                                {
                                    <div class="algo-item">
                                        <div class="algo-header">
                                            <span>@match.DisplayName</span>
                                            <span class="algo-confidence">置信度 @match.Confidence%</span>
                                        </div>
                                        <p>@match.Suggestion</p>
                                        <button class="btn-validate" @onclick="() => VM.ValidateAlgorithmCommand.Execute(match)">🔍 验证算法</button>
                                    </div>
                                }
                            </div>
                            @if (VM.CurrentValidationResult.HasValue)
                            {
                                var vr = VM.CurrentValidationResult.Value;
                                <div class="validation-result @(vr.Passed ? "pass" : "fail")">
                                    <p>@vr.Message</p>
                                    @if (!vr.Passed && vr.FailedCase.HasValue)
                                    {
                                        var fc = vr.FailedCase.Value;
                                        <p class="val-case">用例: @fc.Description [@string.Join(", ", fc.InputArray)]</p>
                                        @if (!string.IsNullOrEmpty(vr.ActualOutput))
                                        {
                                            <p class="val-output">实际输出: @vr.ActualOutput</p>
                                        }
                                    }
                                </div>
                            }
                        }
                        break;
                }
            </div>
        </div>
    </div>
}

<FloatingActionButton OnMenuItemSelected="ShowDebugTab" />

@code {
    private CodeMirrorEditor? _editor;
    private bool _showDebugModal = false;
    private int _debugTabIndex = 0;
    private string _debugModalTitle = "";

    // Touch swipe state for mobile tab switching
    private double _touchStartX;
    private double _touchStartY;
    private bool _touchSwipeHandled;
    private const double SwipeThreshold = 60.0;
    private const double SwipeMaxVertical = 40.0;

    // Modal 下滑关闭手势
    private double _modalTouchStartY;
    private bool _modalSwipeHandled;

    private readonly string[] _debugTabTitles = new[]
    {
        "调用栈", "监视", "变量", "内存", "数组", "指针", "知识卡片", "算法"
    };

    protected override void OnInitialized()
    {
        VM.PropertyChanged += OnPropertyChanged;
    }

    private void OnPropertyChanged(object? sender, System.ComponentModel.PropertyChangedEventArgs e)
    {
        _ = InvokeAsync(async () =>
        {
            StateHasChanged();
            if (_editor is null) return;
            switch (e.PropertyName)
            {
                case nameof(VM.BreakpointLines):
                    await _editor.SetBreakpoints(VM.BreakpointLines.ToList());
                    break;
                case nameof(VM.ErrorLines):
                    await _editor.SetErrorLines(VM.ErrorLines.ToList());
                    break;
                case nameof(VM.HighlightedLine):
                    await _editor.SetHighlightLine(VM.HighlightedLine);
                    break;
            }
        });
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _editor is not null)
        {
            await _editor.SetBreakpoints(VM.BreakpointLines.ToList());
            await _editor.SetErrorLines(VM.ErrorLines.ToList());
            await _editor.SetHighlightLine(VM.HighlightedLine);
        }
    }

    private void OnCodeChanged(string code) => VM.SourceCode = code;

    private async Task InsertTemplate(string code)
    {
        if (_editor is not null)
        {
            await _editor.InsertTemplate(code + "\n");
        }
    }

    private void OnBreakpointToggled(int line)
    {
        if (VM.BreakpointLines.Contains(line))
            VM.BreakpointLines.Remove(line);
        else
            VM.BreakpointLines.Add(line);
    }

    private void ToggleTheme() => VM.IsDarkMode = !VM.IsDarkMode;

    private void ShowDebugTab(int index)
    {
        _debugTabIndex = index;
        _debugModalTitle = _debugTabTitles[index];
        _showDebugModal = true;
        StateHasChanged();
    }

    private void CloseDebugModal()
    {
        _showDebugModal = false;
    }

    public void Dispose()
    {
        VM.PropertyChanged -= OnPropertyChanged;
        VM.Dispose();
    }

    private void OnTouchStart(TouchEventArgs e)
    {
        if (e.Touches.Length > 0)
        {
            _touchStartX = e.Touches[0].ClientX;
            _touchStartY = e.Touches[0].ClientY;
            _touchSwipeHandled = false;
        }
    }

    private void OnTouchMove(TouchEventArgs e)
    {
        if (_touchSwipeHandled || e.Touches.Length == 0) return;

        double dx = e.Touches[0].ClientX - _touchStartX;
        double dy = e.Touches[0].ClientY - _touchStartY;

        if (Math.Abs(dx) > SwipeThreshold && Math.Abs(dy) < SwipeMaxVertical)
        {
            _touchSwipeHandled = true;
            if (dx < 0)
            {
                VM.NextTabCommand.Execute(null); // swipe left → next tab
            }
            else
            {
                VM.PreviousTabCommand.Execute(null); // swipe right → previous tab
            }
        }
    }

    private void OnTouchEnd(TouchEventArgs e)
    {
        _touchSwipeHandled = false;
    }

    private void OnModalTouchStart(TouchEventArgs e)
    {
        if (e.Touches.Length > 0)
        {
            _modalTouchStartY = e.Touches[0].ClientY;
            _modalSwipeHandled = false;
        }
    }

    private void OnModalTouchMove(TouchEventArgs e)
    {
        if (_modalSwipeHandled || e.Touches.Length == 0) return;

        double dy = e.Touches[0].ClientY - _modalTouchStartY;
        if (dy > 100)
        {
            _modalSwipeHandled = true;
            CloseDebugModal();
        }
    }

    private void OnModalTouchEnd(TouchEventArgs e)
    {
        _modalSwipeHandled = false;
    }
}
