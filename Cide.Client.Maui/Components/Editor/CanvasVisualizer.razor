@inject IJSRuntime JS
@implements IAsyncDisposable
@using Cide.Client.Shared.Core

<canvas id="@CanvasId" style="width:100%;height:100%;"></canvas>

@code {
    [Parameter] public string CanvasId { get; set; } = "viz-canvas";
    [Parameter] public List<GraphNodeViewModel>? GraphNodes { get; set; }
    [Parameter] public List<MemoryRegion>? MemoryRegions { get; set; }
    [Parameter] public string Mode { get; set; } = "graph"; // "graph" or "memory"

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await DrawAsync();
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        await DrawAsync();
    }

    private async Task DrawAsync()
    {
        if (Mode == "graph" && GraphNodes != null)
        {
            var nodes = GraphNodes.Select(n => new
            {
                address = n.Address,
                label = n.Label,
                x = n.X,
                y = n.Y,
                nextAddr = n.NextAddr,
                isHighlighted = n.IsHighlighted,
                flashColor = n.FlashColor
            }).ToList();
            await JS.InvokeVoidAsync("canvasInterop.drawLinkedList", CanvasId, nodes);
        }
        else if (Mode == "memory" && MemoryRegions != null)
        {
            var regions = MemoryRegions.Select(r => new
            {
                name = r.Name,
                address = r.Address,
                value = r.Value,
                size = r.Size,
                isHeap = r.IsHeap,
                isFreed = r.IsFreed
            }).ToList();
            await JS.InvokeVoidAsync("canvasInterop.drawMemoryMap", CanvasId, regions);
        }
    }

    public async ValueTask DisposeAsync()
    {
    }
}
