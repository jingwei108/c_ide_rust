@inject IJSRuntime JSRuntime

<div class="fab-wrapper">
    <div class="fab-stack-backdrop @(IsOpen ? "open" : "")" style="@StackBackdropStyle"></div>

    @foreach (var item in _menuItems)
    {
        <button class="fab-menu-item @(IsOpen ? "open" : "")"
                style="@GetMenuItemStyle(item.Index)"
                @ontouchend="() => OnMenuItemClick(item.Index)"
                @ontouchstart:preventDefault>
            @item.Label
        </button>
    }

    <div class="fab-main @(IsOpen ? "open" : "") @(IsDragging ? "dragging" : "")"
         style="@MainButtonStyle"
         @ontouchstart="OnTouchStart"
         @ontouchmove="OnTouchMove"
         @ontouchmove:preventDefault
         @ontouchend="OnTouchEnd">
    </div>
</div>

@code {
    [Parameter] public EventCallback<int> OnMenuItemSelected { get; set; }

    private bool IsOpen = false;
    private bool IsDragging = false;
    private double FabX = 0, FabY = 0;
    private double TouchStartX, TouchStartY;
    private double DragStartFabX, DragStartFabY;
    private double WindowWidth = 0, WindowHeight = 0;
    private bool HasDragged = false;
    private string SnappedSide = "right";
    private DotNetObjectReference<FloatingActionButton>? _dotNetRef;

    private const double FabSize = 56;
    private const double DragThreshold = 8;

    private readonly (int Index, string Label)[] _menuItems = new[]
    {
        (0, "调用栈"),
        (1, "监视变量"),
        (2, "局部变量"),
        (3, "内存区域"),
        (4, "数组可视化"),
        (5, "指针视图"),
        (6, "知识卡片")
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);

            try
            {
                WindowWidth = await JSRuntime.InvokeAsync<double>("eval", "window.innerWidth");
                WindowHeight = await JSRuntime.InvokeAsync<double>("eval", "window.innerHeight");
            }
            catch
            {
                WindowWidth = 400;
                WindowHeight = 800;
            }

            if (!HasDragged && WindowWidth > 0)
            {
                FabX = WindowWidth - FabSize / 2;
                FabY = WindowHeight * 0.65;
                StateHasChanged();
            }

            try
            {
                await JSRuntime.InvokeVoidAsync("eval", $@"
                    window._fabDotNetRef = window._fabDotNetRef || null;
                    window._fabDotNetRef = {_dotNetRef};
                    if (!window._fabResizeHandler) {{
                        window._fabResizeHandler = function() {{
                            if (window._fabDotNetRef) {{
                                window._fabDotNetRef.invokeMethodAsync('OnWindowResize', window.innerWidth, window.innerHeight);
                            }}
                        }};
                        window.addEventListener('resize', window._fabResizeHandler);
                    }}
                ");
            }
            catch { }
        }
    }

    [JSInvokable]
    public void OnWindowResize(int width, int height)
    {
        WindowWidth = width;
        WindowHeight = height;

        if (!HasDragged)
        {
            FabX = WindowWidth - FabSize / 2;
            FabY = WindowHeight * 0.65;
        }
        else
        {
            FabX = Math.Clamp(FabX, FabSize / 2, WindowWidth - FabSize / 2);
            FabY = Math.Clamp(FabY, FabSize / 2 + 48, WindowHeight - FabSize / 2 - 8);
        }

        if (IsOpen)
        {
            IsOpen = false;
        }

        StateHasChanged();
    }

    private string MainButtonStyle
    {
        get
        {
            if (!HasDragged && WindowWidth <= 0)
                return "";

            double x = FabX;
            double y = FabY;

            if (!IsOpen && !IsDragging)
            {
                if (SnappedSide == "right")
                    x = Math.Max(FabSize / 2, WindowWidth - FabSize * 0.25);
                else
                    x = FabSize * 0.25;
            }

            var ci = System.Globalization.CultureInfo.InvariantCulture;
            return $"left: {(x - FabSize / 2).ToString("F1", ci)}px; top: {(y - FabSize / 2).ToString("F1", ci)}px;";
        }
    }

    private string StackBackdropStyle
    {
        get
        {
            if (!HasDragged && WindowWidth <= 0)
                return "";

            double x = FabX;
            double y = FabY;

            if (!IsOpen && !IsDragging)
            {
                if (SnappedSide == "right")
                    x = Math.Max(FabSize / 2, WindowWidth - FabSize * 0.25);
                else
                    x = FabSize * 0.25;
            }

            var ci = System.Globalization.CultureInfo.InvariantCulture;
            return $"left: {x.ToString("F1", ci)}px; top: {y.ToString("F1", ci)}px;";
        }
    }

    private bool ExpandDown => FabY < WindowHeight * 0.5;

    private string GetMenuItemStyle(int index)
    {
        if (!IsOpen || WindowWidth <= 0)
            return "opacity: 0; pointer-events: none; transform: translateX(-50%) scale(0.8);";

        double itemHeight = 44;
        double gap = 8;
        double offset = (index + 1) * (itemHeight + gap);
        double top = ExpandDown ? FabY + offset : FabY - offset - itemHeight;
        double left = FabX;

        var ci = System.Globalization.CultureInfo.InvariantCulture;
        string delay = $"{(index * 40)}ms";
        return $"left: {left.ToString("F1", ci)}px; top: {top.ToString("F1", ci)}px; opacity: 1; pointer-events: auto; transform: translateX(-50%) scale(1); transition-delay: {delay};";
    }

    private void OnTouchStart(TouchEventArgs e)
    {
        if (e.Touches.Length > 0)
        {
            var t = e.Touches[0];
            IsDragging = false;
            TouchStartX = t.ClientX;
            TouchStartY = t.ClientY;
            DragStartFabX = FabX;
            DragStartFabY = FabY;
        }
    }

    private void OnTouchMove(TouchEventArgs e)
    {
        if (e.Touches.Length > 0)
        {
            var t = e.Touches[0];
            double dx = t.ClientX - TouchStartX;
            double dy = t.ClientY - TouchStartY;

            if (!IsDragging && (Math.Abs(dx) > DragThreshold || Math.Abs(dy) > DragThreshold))
            {
                IsDragging = true;
                if (IsOpen)
                {
                    IsOpen = false;
                    StateHasChanged();
                }
            }

            if (IsDragging)
            {
                FabX = DragStartFabX + dx;
                FabY = DragStartFabY + dy;
                HasDragged = true;
                StateHasChanged();
            }
        }
    }

    private void OnTouchEnd(TouchEventArgs e)
    {
        if (IsDragging)
        {
            IsDragging = false;
            HasDragged = true;

            double centerX = FabX;
            SnappedSide = centerX < WindowWidth / 2 ? "left" : "right";

            double minY = 48 + FabSize / 2;
            double maxY = Math.Max(minY, WindowHeight - FabSize / 2 - 8);
            FabY = Math.Clamp(FabY, minY, maxY);

            StateHasChanged();
        }
        else
        {
            ToggleFab();
        }
    }

    private void ToggleFab()
    {
        IsOpen = !IsOpen;
        StateHasChanged();
    }

    private async Task OnMenuItemClick(int index)
    {
        IsOpen = false;
        await OnMenuItemSelected.InvokeAsync(index);
    }
}
