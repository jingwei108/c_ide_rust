root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Rust
[*.rs]
indent_size = 4
indent_style = space
max_line_length = 120

# Dart
[*.dart]
indent_size = 2
indent_style = space
max_line_length = 120

# Python
[*.py]
indent_size = 4
indent_style = space
max_line_length = 120

# C / C++
[*.{c,cpp,h,hpp}]
indent_size = 4
indent_style = space
max_line_length = 120

# YAML
[*.{yml,yaml}]
indent_size = 2
indent_style = space

# JSON / TOML
[*.{json,toml}]
indent_size = 2
indent_style = space

# Markdown
[*.md]
trim_trailing_whitespace = false
max_line_length = 120
